{% style %}

  [data-section-id="{{ section.id }}"] {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  @media (max-width: 768px) {
    [data-section-id="{{ section.id }}"] {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }

{% endstyle %}

{% if section.settings.countdown_month != blank and section.settings.countdown_day != blank and section.settings.countdown_hour != blank %}
<script>
(function() {
    var sectionId = '{{ section.id }}';
    var NEW_YORK_TIME_ZONE = 'America/New_York';

    function pad(value) {
        return String(value).padStart(2, '0');
    }

    function parseMonth(monthRaw) {
        var numericMonth = parseInt(monthRaw, 10);

        if (!Number.isNaN(numericMonth) && numericMonth >= 1 && numericMonth <= 12) {
            return numericMonth - 1;
        }

        var parsed = Date.parse((monthRaw || '').trim() + ' 1, 2000');
        if (Number.isNaN(parsed)) return null;

        return new Date(parsed).getMonth();
    }

    function getTimeZoneParts(date, timeZone) {
        var formatter = new Intl.DateTimeFormat('en-US', {
            timeZone: timeZone,
            year: 'numeric',
            month: '2-digit',
            day: '2-digit',
            hour: '2-digit',
            minute: '2-digit',
            second: '2-digit',
            hour12: false
        });

        var parts = formatter.formatToParts(date);
        var map = {};

        parts.forEach(function(part) {
            if (part.type !== 'literal') {
                map[part.type] = parseInt(part.value, 10);
            }
        });

        return {
            year: map.year,
            month: map.month,
            day: map.day,
            hour: map.hour,
            minute: map.minute,
            second: map.second
        };
    }

    function getTimeZoneOffsetMs(date, timeZone) {
        var tzParts = getTimeZoneParts(date, timeZone);
        var asUtc = Date.UTC(
            tzParts.year,
            tzParts.month - 1,
            tzParts.day,
            tzParts.hour,
            tzParts.minute,
            tzParts.second
        );

        return asUtc - date.getTime();
    }

    function createDateInTimeZone(year, monthIndex, day, hour, timeZone) {
        var utcGuess = Date.UTC(year, monthIndex, day, hour, 0, 0, 0);
        var guessDate = new Date(utcGuess);
        var offset = getTimeZoneOffsetMs(guessDate, timeZone);
        var targetTime = utcGuess - offset;
        var correctedOffset = getTimeZoneOffsetMs(new Date(targetTime), timeZone);

        if (correctedOffset !== offset) {
            targetTime = utcGuess - correctedOffset;
        }

        return new Date(targetTime);
    }

    function getCurrentYearInTimeZone(timeZone) {
        return getTimeZoneParts(new Date(), timeZone).year;
    }

    function buildTargetDate(countdown) {
        var monthRaw = countdown.dataset.countdownMonth;
        var dayRaw = countdown.dataset.countdownDay;
        var hourRaw = countdown.dataset.countdownHour;

        if (!monthRaw || !dayRaw || !hourRaw) return null;

        var monthIndex = parseMonth(monthRaw);
        var day = parseInt(dayRaw, 10);
        var hour = parseInt(hourRaw, 10);

        if (monthIndex === null || Number.isNaN(day) || Number.isNaN(hour)) return null;
        if (day < 1 || day > 31 || hour < 0 || hour > 23) return null;

        var year = getCurrentYearInTimeZone(NEW_YORK_TIME_ZONE);
        var target = createDateInTimeZone(year, monthIndex, day, hour, NEW_YORK_TIME_ZONE);
        var targetParts = getTimeZoneParts(target, NEW_YORK_TIME_ZONE);

        if (
            targetParts.year !== year ||
            targetParts.month !== monthIndex + 1 ||
            targetParts.day !== day ||
            targetParts.hour !== hour
        ) {
            return null;
        }

        return target;
    }

    function render(timeLeftMs, elements) {
        var totalSeconds = Math.floor(timeLeftMs / 1000);
        var days = Math.floor(totalSeconds / 86400);
        var hours = Math.floor((totalSeconds % 86400) / 3600);
        var minutes = Math.floor((totalSeconds % 3600) / 60);
        var seconds = totalSeconds % 60;

        if (elements.days) elements.days.textContent = pad(days);
        if (elements.hours) elements.hours.textContent = pad(hours);
        if (elements.minutes) elements.minutes.textContent = pad(minutes);
        if (elements.seconds) elements.seconds.textContent = pad(seconds);
    }

    function init() {
        var section = document.querySelector('[data-section-id="' + sectionId + '"]');
        if (!section) return;

        var countdown = section.querySelector('.countdown-area');
        if (!countdown) return;

        if (countdown._interval) {
            window.clearInterval(countdown._interval);
            countdown._interval = null;
        }

        var elements = {
            days: countdown.querySelector('[data-unit="days"]'),
            hours: countdown.querySelector('[data-unit="hours"]'),
            minutes: countdown.querySelector('[data-unit="minutes"]'),
            seconds: countdown.querySelector('[data-unit="seconds"]')
        };

        var targetDate = buildTargetDate(countdown);

        // Keep initial 00 values if settings are incomplete.
        if (!targetDate) return;

        function tick() {
            var diff = targetDate.getTime() - Date.now();

            // Keep 00s once countdown is complete.
            if (diff <= 0) {
                window.clearInterval(countdown._interval);
                return;
            }

            render(diff, elements);
        }

        var initialDiff = targetDate.getTime() - Date.now();

        if (initialDiff <= 0) return;

        tick();
        countdown._interval = window.setInterval(tick, 1000);
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }

    document.addEventListener('shopify:section:load', function(event) {
        if (!event.detail || event.detail.sectionId !== sectionId) return;
        init();
    });
})();
</script>
{% endif %}

<section data-section-id="{{ section.id }}" {% if section.settings.section_anchor_id %} id="{{ section.settings.section_anchor_id }}" {% endif %}>
    <div class="inner-container mw-1200">
        {% if section.settings.countdown_month != blank and section.settings.countdown_day != blank and section.settings.countdown_hour != blank %}
            <div class="countdown-area-container">
                {% if section.settings.countdown_text %}
                    <span>{{ section.settings.countdown_text }}</span>
                {% endif %}
                <div
                class="countdown-area"
                data-countdown-month="{{ section.settings.countdown_month | escape }}"
                data-countdown-day="{{ section.settings.countdown_day | escape }}"
                data-countdown-hour="{{ section.settings.countdown_hour | escape }}"
                >
                    <div>
                        <span data-unit="days">00</span>
                        <span class="countdown-label" data-label="days">Days</span>
                    </div>
                    <div>
                        <span data-unit="hours">00</span>
                        <span class="countdown-label" data-label="hours">Hours</span>
                    </div>
                    <div>
                        <span data-unit="minutes">00</span>
                        <span class="countdown-label" data-label="minutes">Minutes</span>
                    </div>
                    <div>
                        <span data-unit="seconds">00</span>
                        <span class="countdown-label" data-label="seconds">Seconds</span>
                    </div>
                </div>
            </div>
        {% endif %}
        <div class="prize-area">
            {% if section.settings.prize_image %}
                <img src="{{ section.settings.prize_image | img_url: 'master' }}" alt="Prize Image">
            {% endif %}
            {% if section.settings.prize_html %}
                <div class="prize-text-container">
                    <h2>Sweepstakes Prize:</h2>
                    <h3>Invincible</h3>
                    <h5> PRIZE: Series of 3 Original Hand Drawn Production Art from Season 1 of the Amazon Prime series Invincible, individually framed.</h5>
                </div>
            {% endif %}
        </div>
    </div>
</section>

{% schema %}
{
  "name": "Sweepstakes banner",
  "enabled_on": {
    "templates": ["product", "collection", "page", "index", "article", "blog", "404", "cart", "search"]
  },
  "settings": [
    {
      "type": "text",
      "id": "section_anchor_id",
      "label": "Section Anchor ID (optional)"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Top (Desktop)",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom (Desktop)",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Top (Mobile)",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom (Mobile)",
      "default": 0
    },
    {
      "type": "text",
      "id": "countdown_text",
      "label": "Countdown Text",
      "default": "Sweepstakes ends in:"
    },
    {
      "type": "header",
      "content": "Countdown Date and Time (NYC)"
    },
    {
      "type": "paragraph",
      "content": "Enter month/day/hour as numbers in New York time (24-hour format). Example: Month 7, Day 7, Hour 20 = July 7 at 8:00 PM NYC."
    },
    {
      "type": "text",
      "id": "countdown_month",
      "label": "Countdown Month"
    },
    {
      "type": "text",
      "id": "countdown_day",
      "label": "Countdown Day"
    },
    {
      "type": "text",
      "id": "countdown_hour",
      "label": "Countdown Hour"
    },
    {
      "type": "header",
      "content": "Prize Section"
    },
    {
      "type": "image_picker",
      "id": "prize_image",
      "label": "Prize Image"
    },
    {
      "type": "html",
      "id": "prize_html",
      "label": "Prize HTML"
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "Sweepstakes banner"
    }
  ]
}
{% endschema %}