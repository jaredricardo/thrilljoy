{% style %}

    [data-section-id="{{ section.id }}"] {
    background-color: {{ section.settings.bg_color }};
    }

    [data-section-id="{{ section.id }}"] h1 {
        color: {{ section.settings.heading_color }};
        font-style: italic;
        margin-left: 0.5rem;
    }

    @media screen and (max-width: 768px) {
        [data-section-id="{{ section.id }}"] h1 {
            font-size: 2rem;
        }
    }

{% endstyle %}

<section class="sweepstakes-header" data-section-id="{{ section.id }}" {% if section.settings.section_anchor_id %} id="{{ section.settings.section_anchor_id }}" {% endif %}>
    <div class="inner-container">
        <img src="{{ section.settings.image |  img_url: 'master'}}" alt="Thrilljoy Image">
        <h1>{{ section.settings.heading }}</h1>
    </div>
</section>

{% schema %}
{
  "name": "Sweepstakes Header",
  "enabled_on": {
    "templates": ["product", "collection", "page", "index", "article", "blog", "404", "cart", "search"]
  },
  "settings": [
    {
      "type": "text",
      "id": "section_anchor_id",
      "label": "Section Anchor ID (optional)"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Header Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "SWEEPSTAKES"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#000000"
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "Sweepstakes Header"
    }
  ]
}
{% endschema %}