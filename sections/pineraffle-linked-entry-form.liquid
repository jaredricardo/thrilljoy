{% style %}

  [data-section-id="{{ section.id }}"] {
    background-color: {{ section.settings.bg_color }};
  }

{% endstyle %}

<style>
    
    /* hide pine raffle by default. We will use javascript to enter the form fields with the user's input in our custom form */

  div:has(#pr-widget-container) {
    /* display: none; */
  }

  /* Section Layout */
  .pineraffle-proxy-section {
    padding: 40px 20px;
  }

  .pineraffle-proxy-section .row {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    max-width: 1200px;
    margin: 0 auto;
    align-items: stretch;
  }

  .pineraffle-proxy-section .col {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .pineraffle-proxy-section .col img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 12px;
  }

  .pineraffle-proxy-section form {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  /* Stack columns on tablet and smaller */
  @media (max-width: 768px) {
    .pineraffle-proxy-section .row {
      flex-direction: column;
    }
    
    .pineraffle-proxy-section .col {
      width: 100%;
    }
  }

  /* Typography */
  .pineraffle-proxy-section h4 {
    font-family: Montserrat, sans-serif;
    font-weight: 700;
    font-style: normal;
    font-size: 30px;
    line-height: 100%;
    letter-spacing: 0%;
    text-align: center;
    margin-bottom: 24px;
  }

  .pineraffle-proxy-section p {
    font-family: Montserrat, sans-serif;
    font-weight: 700;
    font-style: normal;
    font-size: 21px;
    line-height: 100%;
    letter-spacing: 0%;
    text-align: center;
    margin-top: 40px;
  }

  /* Form Styling */
  .pineraffle-proxy-section form {
    background-color: white;
    border: 3px solid #1A9DD1;
    border-radius: 24px;
    padding: 30px;
    color: black;
  }

  /* Form Layout - Grid for first/last name row */
  .pineraffle-proxy-section form input[type="text"],
  .pineraffle-proxy-section form input[type="email"] {
    width: 100%;
    padding: 12px 16px;
    margin-bottom: 16px;
    border: 1px solid #ddd;
    border-radius: 8px;
    font-size: 14px;
    box-sizing: border-box;
  }

  /* First and Last name in same row */
  .pineraffle-proxy-section form #first-name,
  .pineraffle-proxy-section form #last-name {
    width: calc(50% - 8px);
    display: inline-block;
  }

  .pineraffle-proxy-section form #first-name {
    margin-right: 8px;
  }

  .pineraffle-proxy-section form #last-name {
    margin-left: 8px;
  }

  /* Checkbox styling */
  .pineraffle-proxy-section form input[type="checkbox"] {
    margin-right: 8px;
    width: 18px;
    height: 18px;
    cursor: pointer;
  }

  .pineraffle-proxy-section form label {
    display: block;
    margin-bottom: 16px;
    font-size: 14px;
    line-height: 1.4;
    cursor: pointer;
  }

  .pineraffle-proxy-section form input[type="checkbox"] + label {
    display: inline-block;
    vertical-align: middle;
    width: calc(100% - 26px);
  }

  /* Submit button */
  .pineraffle-proxy-section form button[type="submit"] {
    width: 100%;
    padding: 14px 24px;
    background-color: #1A9DD1;
    color: white;
    border: none;
    border-radius: 9px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    margin-top: 8px;
    transition: background-color 0.3s ease;
  }

  .pineraffle-proxy-section form button[type="submit"]:hover {
    background-color: #1588b8;
  }

  /* Mobile adjustments for first/last name */
  @media (max-width: 480px) {
    .pineraffle-proxy-section form #first-name,
    .pineraffle-proxy-section form #last-name {
      width: 100%;
      margin: 0 0 16px 0;
    }
  }

</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const form = document.querySelector('.pineraffle-proxy-section form')
    
    if (form) {
      form.addEventListener('submit', function(e) {
        e.preventDefault()
        
        // Get all form field values
        const formData = {
          firstName: document.getElementById('first-name').value,
          lastName: document.getElementById('last-name').value,
          email: document.getElementById('email').value,
          rulesRead: document.getElementById('rules-read').checked,
          newsletterConsent: document.getElementById('newsletter-consent').checked
        }
        
        // Log the form data
        console.log('Form submitted with the following data:')
        console.log(formData)
        console.log('---')
        console.log('First Name:', formData.firstName)
        console.log('Last Name:', formData.lastName)
        console.log('Email:', formData.email)
        console.log('Rules Read & Agreed:', formData.rulesRead)
        console.log('Newsletter Consent:', formData.newsletterConsent)
        
        // Add your form submission logic here
        // For now, just logging the data
      })
    }
  })
</script>

<section data-section-id="{{ section.id }}" class="pineraffle-proxy-section" {% if section.settings.section_anchor_id %} id="{{ section.settings.section_anchor_id }}" {% endif %}>
    <div class="row">
        <div class="col">
            <img src="{{ section.settings.raffle_image |  image_url: width: 900  }}" alt="Raffle Image">
        </div>
        <div class="col">
            <form action="submit">
                <h4>ENTER SWEEPSTAKES NOW</h4>
                <input type="text" id="first-name" placeholder="FIRST NAME">
                <input type="text" id="last-name" placeholder="LAST NAME">
                <input type="email" id="email" placeholder="EMAIL ADDRESS">
                <input type="checkbox" id="rules-read" name="rules-read" required>
                <label for="rules-read">I have read and agree to the official rules*</label>
                <input type="checkbox" id="newsletter-consent" name="newsletter-consent">
                <label for="newsletter-consent">Yes, send me newsletters, special offers, and promotional emails from Thrilljoy</label>
                <button type="submit">SUBMIT</button>
            </form>
        </div>
    </div>
    <p>*NO PURCHASE NECESSARY. Open to legal residents of 50 U.S./D.C., 18+ or age of majority. 7/22/26–8/22/26. Win a series of 3 original hand drawn production art from Season 1 of the Amazon Prime series Invincible, individually framed (ARV: $1,500 USD). Odds depend on entries. Void where prohibited. Sponsored by Thrilljoy.</p>
</section>

{% schema %}
{
  "name": "Custom Pine Raffle Form",
  "enabled_on": {
    "templates": ["page"]
  },
  "settings": [
    {
        "type": "header",
        "content": "Pine Raffle Form Proxy",
        "info": "The Pine Raffle form is embedded via a (hidden) Shopify app embed. If that embed is not present, this section will not work correctly.."
    },
    {
      "type": "image_picker",
      "id": "raffle_image",
      "label": "Raffle Image"
    },
    {
      "type": "text",
      "id": "section_anchor_id",
      "label": "Section Anchor ID (optional)"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "Custom Pine Raffle Form"
    }
  ]
}
{% endschema %}