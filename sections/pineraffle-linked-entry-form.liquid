{% style %}

  [data-section-id="{{ section.id }}"] {
    background-color: {{ section.settings.bg_color }};
  }

{% endstyle %}

<style>
    
    /* hide pine raffle by default. We will use javascript to enter the form fields with the user's input in our custom form */

  div:has(#pr-widget-container) {
    /* display: none; */
  }

  /* Section Layout */
  .pineraffle-proxy-section {
    padding: 40px 20px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .pineraffle-proxy-section .row {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    max-width: 1200px;
    margin: 0 auto;
    align-items: flex-start;
  }

  .pineraffle-proxy-section .col {
    flex: 1;
    align-self: center;
  }

  .pineraffle-proxy-section .col:nth-of-type(1) {
    position: relative;
    height: 550px;
  }

  .pineraffle-proxy-section .col img {
    width: 100%;
    height: 110%;
    object-fit: contain;
    display: block;
    border-radius: 12px;
    position: absolute;
    bottom: 5%;
  }

  /* Stack columns on tablet and smaller */
  @media (max-width: 768px) {
    .pineraffle-proxy-section .row {
      flex-direction: column;
    }
    
    .pineraffle-proxy-section .col {
      width: 100%;
    }
  }

  /* Typography */
  .pineraffle-proxy-section h4 {
    font-family: Montserrat, sans-serif;
    font-weight: 700;
    font-style: normal;
    font-size: 30px;
    line-height: 100%;
    letter-spacing: 0%;
    text-align: center;
    margin-top: 0;
    margin-bottom: 24px;
  }

  .pineraffle-proxy-section p {
    font-family: Montserrat, sans-serif;
    font-weight: 700;
    font-style: normal;
    font-size: 21px;
    line-height: 110%;
    letter-spacing: 0%;
    text-align: center;
    margin-top: 30px;
    color: black;
  }

  /* Form Styling */
  .pineraffle-proxy-section form {
    background-color: white;
    border: 3px solid #1A9DD1;
    border-radius: 24px;
    padding: 30px;
    color: black;
  }

  /* Form Layout - Grid for first/last name row */
  .pineraffle-proxy-section form input[type="text"],
  .pineraffle-proxy-section form input[type="email"] {
    width: 100%;
    padding: 12px 16px;
    margin-bottom: 16px;
    border: 1px solid #ddd;
    border-radius: 8px;
    font-size: 14px;
    box-sizing: border-box;
  }

  /* First and Last name in same row */
  .pineraffle-proxy-section form .name-row {
    display: flex;
    gap: 16px;
    margin-bottom: 16px;
  }

  .pineraffle-proxy-section form #first-name,
  .pineraffle-proxy-section form #last-name {
    flex: 1;
    margin-bottom: 0;
  }

  /* Checkbox styling */
  .pineraffle-proxy-section form .checkbox-row {
    display: flex;
    align-items: flex-start;
    margin-bottom: 16px;
    gap: 8px;
  }

  .pineraffle-proxy-section form input[type="checkbox"] {
    width: 18px;
    height: 18px;
    cursor: pointer;
    margin-top: 2px;
    flex-shrink: 0;
  }

  .pineraffle-proxy-section form label {
    font-size: 14px;
    line-height: 1.4;
    cursor: pointer;
    margin: 0;
  }

  /* Submit button */
  .pineraffle-proxy-section form button[type="submit"] {
    width: 100%;
    padding: 14px 24px;
    background-color: black;
    color: white;
    border: none;
    border-radius: 9px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    margin-top: 8px;
    transition: background-color 0.3s ease;
  }

  .pineraffle-proxy-section form button[type="submit"]:hover {
    background-color: #1a9cd1;
  }

  /* Loading spinner */
  .proxy-loading-container {
    display: none;
    text-align: center;
    padding: 60px 30px;
    background-color: white;
    border: 3px solid #1A9DD1;
    border-radius: 24px;
  }

  .proxy-loading-container.active {
    display: block;
  }

  .proxy-spinner {
    display: flex;
    border: 4px solid #f3f3f3;
    border-top: 4px solid #1A9DD1;
    border-radius: 50%;
    width: 50px;
    height: 50px;
    animation: spin 1s linear infinite;
    margin: 0 auto 20px;
  }

  @keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  .proxy-loading-container p {
    font-size: 18px;
    margin: 0 0 10px 0;
    color: #333;
  }
  
  .proxy-loading-container p.subtitle {
    font-size: 14px;
    margin: 10px 0 0 0;
    color: #666;
  }

  /* Success/Already Joined messages */
  .proxy-message-container {
    display: none;
    text-align: center;
    padding: 60px 30px;
    background-color: white;
    border: 3px solid #1A9DD1;
    border-radius: 24px;
  }

  .proxy-message-container.active {
    display: block;
  }

  .proxy-message-container svg {
    margin: 0 auto 20px;
    display: block;
    stroke: #1A9DD1;
  }

  .proxy-message-container h2 {
    font-family: Montserrat, sans-serif;
    font-weight: 700;
    font-size: 24px;
    margin: 0 0 15px 0;
    color: #1A9DD1;
  }

  .proxy-message-container p {
    font-family: Montserrat, sans-serif;
    font-size: 16px;
    line-height: 1.4;
    margin: 15px 0 0 0;
    color: #333;
  }

  /* Mobile adjustments for first/last name */
  @media (max-width: 768px) {
    .pineraffle-proxy-section form .name-row {
      flex-direction: column;
      gap: 0;
      margin-bottom: 0;
    }
    
    .pineraffle-proxy-section form #first-name,
    .pineraffle-proxy-section form #last-name {
      margin-bottom: 16px;
    }
    .pineraffle-proxy-section .col:nth-of-type(1) {
        z-index: 1;
        height: 250px;
    }
    .pineraffle-proxy-section .col {
        flex: auto; 
        z-index: 2;
    }
    .pineraffle-proxy-section .col img {
        bottom: -55%;
        height: 180%;
    }
    .pineraffle-proxy-section form {
        padding: 15px;  
    }
    .pineraffle-proxy-section h4 {
        font-size: 28px;
        margin-bottom: 16px;
    }
    .pineraffle-proxy-section p {
        margin-top: 20px;
        margin-bottom: 0px;
    }
    
    .proxy-loading-container,
    .proxy-message-container {
      padding: 40px 20px;
    }
    
    .proxy-message-container h2 {
      font-size: 20px;
    }
  }

</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Clear sessionStorage on page load to prevent form from defaulting to success message
    sessionStorage.removeItem('pine_raffle_formSubmitted')
    
    const proxyForm = document.getElementById('proxy-raffle-form')
    const proxyFirstName = document.getElementById('proxy-first-name')
    const proxyLastName = document.getElementById('proxy-last-name')
    const proxyEmail = document.getElementById('proxy-email')
    
    // Function to get PineRaffle form fields
    function getPineRaffleFields() {
      const pineRaffleForm = document.getElementById('pineraff-customer-details-form')
      if (!pineRaffleForm) return null
      
      return {
        form: pineRaffleForm,
        firstName: pineRaffleForm.querySelector('input[name="first-name"]'),
        lastName: pineRaffleForm.querySelector('input[name="last-name"]'),
        email: pineRaffleForm.querySelector('input[name="email"]')
      }
    }
    
    // Real-time sync: Update PineRaffle form as user types in proxy form
    if (proxyFirstName) {
      proxyFirstName.addEventListener('input', function() {
        const prFields = getPineRaffleFields()
        if (prFields && prFields.firstName) {
          prFields.firstName.value = this.value
        }
      })
    }
    
    if (proxyLastName) {
      proxyLastName.addEventListener('input', function() {
        const prFields = getPineRaffleFields()
        if (prFields && prFields.lastName) {
          prFields.lastName.value = this.value
        }
      })
    }
    
    if (proxyEmail) {
      proxyEmail.addEventListener('input', function() {
        const prFields = getPineRaffleFields()
        if (prFields && prFields.email) {
          prFields.email.value = this.value
        }
      })
    }
    
    // Handle form submission
    if (proxyForm) {
      proxyForm.addEventListener('submit', function(e) {
        e.preventDefault()
        
        // Get proxy form field values
        const firstName = proxyFirstName.value.trim()
        const lastName = proxyLastName.value.trim()
        const email = proxyEmail.value.trim()
        const rulesRead = document.getElementById('proxy-rules-read').checked
        const newsletterConsent = document.getElementById('proxy-newsletter-consent').checked
        
        // Validate fields
        if (!firstName) {
          alert('Please enter your first name')
          return
        }
        
        if (!lastName) {
          alert('Please enter your last name')
          return
        }
        
        if (!email) {
          alert('Please enter your email address')
          return
        }
        
        // Validate email format
        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/
        if (!emailRegex.test(email)) {
          alert('Please enter a valid email address')
          return
        }
        
        if (!rulesRead) {
          alert('You must agree to the official rules to enter')
          return
        }
        
        // Get PineRaffle form (fields should already be synced)
        const prFields = getPineRaffleFields()
        
        if (prFields && prFields.form) {
          
          // Click the PineRaffle submit button to trigger all functionality
          const submitButton = document.getElementById('pineraff-save-button') || 
                               prFields.form.querySelector('.pineraff-save-button') ||
                               prFields.form.querySelector('button[type="submit"]')
          
          if (submitButton) {
            // Hide form and show loading spinner
            proxyForm.style.display = 'none'
            const loadingContainer = document.getElementById('proxy-loading-container')
            if (loadingContainer) {
              loadingContainer.classList.add('active')
            }
            
            // Click the PineRaffle submit button
            submitButton.click()
            
            // Poll for PineRaffle response
            let pollAttempts = 0
            const maxPollAttempts = 30 // 30 seconds max
            
            const pollInterval = setInterval(function() {
              pollAttempts++
              
              const successMessage = document.getElementById('pineraff-success-message-cont')
              const alreadyJoinedMessage = document.getElementById('pineraff-already-joined-message-cont')
              
              const isSuccess = successMessage && (successMessage.style.display === 'flex' || successMessage.style.display === 'block')
              const isAlreadyJoined = alreadyJoinedMessage && (alreadyJoinedMessage.style.display === 'flex' || alreadyJoinedMessage.style.display === 'block')
              
              if (isSuccess || isAlreadyJoined) {
                clearInterval(pollInterval)
                
                // Hide loading spinner
                if (loadingContainer) {
                  loadingContainer.classList.remove('active')
                }
                
                // Show appropriate message
                const messageContainer = document.getElementById('proxy-message-container')
                const messageTitle = document.getElementById('proxy-message-title')
                const messageSvg = document.getElementById('proxy-message-svg')
                const emailNote = document.getElementById('proxy-email-note')
                
                if (messageContainer && messageTitle && messageSvg) {
                  if (isSuccess) {
                    messageTitle.textContent = 'Entered Successfully!'
                    messageSvg.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="80px" height="80px" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-check-circle"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>'
                    if (emailNote) {
                      emailNote.style.display = 'block'
                    }
                  } else if (isAlreadyJoined) {
                    messageTitle.textContent = 'Already Joined!'
                    messageSvg.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="80px" height="80px" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-info"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>'
                    if (emailNote) {
                      emailNote.style.display = 'none'
                    }
                  }
                  
                  messageContainer.classList.add('active')
                }
              } else if (pollAttempts >= maxPollAttempts) {
                clearInterval(pollInterval)
                if (loadingContainer) {
                  loadingContainer.classList.remove('active')
                }
                proxyForm.style.display = 'block'
              }
            }, 1000) // Check every 1 second
            
          } else {
            alert('Unable to submit entry. Please contact support.')
          }
        } else {
          alert('Unable to submit entry. Please contact support.')
        }
      })
    }
  })
</script>

<section data-section-id="{{ section.id }}" class="pineraffle-proxy-section" {% if section.settings.section_anchor_id %} id="{{ section.settings.section_anchor_id }}" {% endif %}>
    <div class="row">
        <div class="col">
            <img src="{{ section.settings.raffle_image |  image_url: width: 900  }}" alt="Raffle Image">
        </div>
        <div class="col">
            {% comment %} <h4 style="color: red;">SUBMISSIONS CURRENTLY OFFLINE DUE TO TECHNICAL DIFFICULTIES. WE WILL BE BACK ASAP! ❤️</h4> {% endcomment %}
            <form id="proxy-raffle-form" action="submit">
                <h4>ENTER SWEEPSTAKES NOW</h4>
                <div class="name-row">
                    <input type="text" id="proxy-first-name" placeholder="FIRST NAME" required>
                    <input type="text" id="proxy-last-name" placeholder="LAST NAME" required>
                </div>
                <input type="email" id="proxy-email" placeholder="EMAIL ADDRESS" required>
                <div class="checkbox-row">
                    <input type="checkbox" id="proxy-rules-read" name="rules-read" required>
                    <label for="proxy-rules-read">I have read and agree to the official rules*</label>
                </div>
                <div class="checkbox-row">
                    <input type="checkbox" id="proxy-newsletter-consent" name="newsletter-consent">
                    <label for="proxy-newsletter-consent">Yes, send me newsletters, special offers, and promotional emails from Thrilljoy</label>
                </div>
                <button type="submit">SUBMIT</button>
            </form>
            
            <div id="proxy-loading-container" class="proxy-loading-container">
                <div class="proxy-spinner"></div>
                <p>Submitting your entry...</p>
                <p class="subtitle">This may take up to 60 seconds</p>
            </div>
            
            <div id="proxy-message-container" class="proxy-message-container">
                <div id="proxy-message-svg"></div>
                <h2 id="proxy-message-title"></h2>
                <p id="proxy-email-note" style="display: none;">Please check your email, including spam folders, to confirm your successful entry. Email confirmation may take up to 5 minutes to appear with email provider.</p>
            </div>
        </div>
    </div>
    <p>*NO PURCHASE NECESSARY. Open to legal residents of 50 U.S./D.C., 18+ or age of majority. 7/22/26–8/22/26. Win a series of 3 original hand drawn production art from Season 1 of the Amazon Prime series Invincible, individually framed (ARV: $1,500 USD). Odds depend on entries. Void where prohibited. Sponsored by Thrilljoy.</p>
</section>

{% schema %}
{
  "name": "Custom Pine Raffle Form",
  "enabled_on": {
    "templates": ["page"]
  },
  "settings": [
    {
        "type": "header",
        "content": "Pine Raffle Form Proxy",
        "info": "The Pine Raffle form is embedded via a (hidden) Shopify app embed. If that embed is not present, this section will not work correctly.."
    },
    {
      "type": "image_picker",
      "id": "raffle_image",
      "label": "Raffle Image"
    },
    {
      "type": "text",
      "id": "section_anchor_id",
      "label": "Section Anchor ID (optional)"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "Custom Pine Raffle Form"
    }
  ]
}
{% endschema %}