{% style %}

  [data-section-id="{{ section.id }}"] {
    background-color: {{ section.settings.bg_color }};
    {% if section.settings.background_image %}
    background-image: url('{{ section.settings.background_image | image_url: width: 2000 }}');
    background-size: cover;
    background-position: center;
    {% if section.settings.bg_image_repeat %}
    background-repeat: repeat;
    background-size: auto;
    {% else %}
    background-repeat: no-repeat;
    {% endif %}
    {% endif %}
    padding-top: {{ section.settings.padding_y_desktop }}px;
    padding-bottom: {{ section.settings.padding_y_desktop }}px;
    color: {{ section.settings.text_color }};
  }

  [data-section-id="{{ section.id }}"] h1,
  [data-section-id="{{ section.id }}"] h2,
  [data-section-id="{{ section.id }}"] h3,
  [data-section-id="{{ section.id }}"] h4,
  [data-section-id="{{ section.id }}"] h5,
  [data-section-id="{{ section.id }}"] h6,
  [data-section-id="{{ section.id }}"] p,
  [data-section-id="{{ section.id }}"] a,
  [data-section-id="{{ section.id }}"] li,
  [data-section-id="{{ section.id }}"] span {
    color: {{ section.settings.text_color }};
    margin: 0;
  }

  [data-section-id="{{ section.id }}"] .col:first-child {
    flex: 0 0 {{ section.settings.left_column_width }}%;
    max-width: {{ section.settings.left_column_width }}%;
  }

  [data-section-id="{{ section.id }}"] .col:last-child {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (max-width: 768px) {
    [data-section-id="{{ section.id }}"] {
      padding-top: {{ section.settings.padding_y_mobile }}px;
      padding-bottom: {{ section.settings.padding_y_mobile }}px;
    }
    
    [data-section-id="{{ section.id }}"] .col:first-child,
    [data-section-id="{{ section.id }}"] .col:last-child {
      flex: 0 0 100%;
      max-width: 100%;
    }
  }

{% endstyle %}

<section data-section-id="{{ section.id }}" {% if section.settings.section_anchor_id %} id="{{ section.settings.section_anchor_id }}" {% endif %}>
    <div class="fifty-fifty-with-html">
        {% if section.settings.header_html_content %}
            {{ section.settings.header_html_content }}
        {% endif %}
        <div class="col-area">
            {% if section.settings.switch_columns %}
            <div class="col">
                {{ section.settings.html_content }}
            </div>
            <div class="col">
                <img src="{{ section.settings.image | image_url: width: 900 }}" alt="Thilljoy Image">
            </div>
            {% else %}
            <div class="col">
                <img src="{{ section.settings.image | image_url: width: 900 }}" alt="Thilljoy Image">
            </div>
            <div class="col">
                {{ section.settings.html_content }}
            </div>
            {% endif %}
        </div>
    </div>
</section>

{% schema %}
{
  "name": "5050 with HTML",
  "enabled_on": {
    "templates": ["product", "collection", "page", "index", "article", "blog", "404", "cart", "search"]
  },
  "settings": [
    {
      "type": "header",
      "content": "General Settings"
    },
    {
      "type": "text",
      "id": "section_anchor_id",
      "label": "Section Anchor ID (optional)"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image",
      "info": "Optional background image for the section"
    },
    {
      "type": "checkbox",
      "id": "bg_image_repeat",
      "label": "Repeat Background Image",
      "default": false,
      "info": "Check to tile/repeat the background image instead of covering the section"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_y_desktop",
      "label": "Vertical Padding - Desktop",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_y_mobile",
      "label": "Vertical Padding - Mobile",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Column Width (Desktop Only)"
    },
    {
      "type": "range",
      "id": "left_column_width",
      "label": "Left Column Width",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 50,
      "info": "Left and right columns should add up to 100%"
    },
    {
      "type": "range",
      "id": "right_column_width",
      "label": "Right Column Width",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 50
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "checkbox",
      "id": "switch_columns",
      "label": "Switch Columns Order",
      "default": false,
      "info": "Check to display HTML content on the left and image on the right"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "liquid",
      "id": "header_html_content",
      "label": "Header HTML Content"
    },
    {
      "type": "liquid",
      "id": "html_content",
      "label": "HTML Content"
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "5050 with HTML"
    }
  ]
}
{% endschema %}